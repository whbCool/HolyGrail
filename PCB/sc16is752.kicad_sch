	(text "3 to 8 line decoder that translates a 3-bit binary address from the ESP32 into\neight individual selection signals, allowing the ESP32 to address up to eight independent \nbridge chips using chip select expansion.\n\nThis ensures that only one device is active on the shared SPI data bus at any given time."
		(exclude_from_sim no)
		(at 82.55 189.23 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "25b96b30-a4e0-4066-86a5-f4541a0bb01f")
	)
	(text "Tri-state line driver that isolates the data lines\ncoming from the SC16IS752 bridges, protecting\nthe ESP32 from signal degradation."
		(exclude_from_sim no)
		(at 193.802 140.716 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "593a9b65-3b34-46b2-b59c-5bfaf58aa6aa")
	)
	(text "Spare Decoupling\nCapacitors"
		(exclude_from_sim no)
		(at 202.438 129.794 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "ad674edd-3275-49c7-9b38-d61b18626a39")
	)
	(text_box "12 sensors are monitored via an array of 6 SC16IS752IPW dual-UART bridge chips. \n\nThis configuration multiplexes 12 data streams onto a shared high-speed SPI bus, reducing the ESP32's required GPIO overhead."
		(exclude_from_sim no)
		(at 14.478 120.142 0)
		(size 88.646 12.7)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width -0.0001)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "c85a41b2-91ca-407f-91cd-52c8197d9238")
	)
