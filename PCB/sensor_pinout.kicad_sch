	(paper "A4")
	(title_block
		(title "DB25 Pinout")
	)
	(lib_symbols)
	(text "Make sure to check all connections prior to connecting to power. \n\nIncorrect wiring can cause permanent damage to sensors and/or\nboard. "
		(exclude_from_sim no)
		(at 13.462 173.99 0)
		(effects
			(font
				(size 2.794 2.794)
				(bold yes)
				(color 210 0 7 1)
			)
			(justify left)
		)
		(uuid "40cabc15-567f-465c-9758-47ceef0d568a")
	)
	(text_box "This is the pinout for a custom female DB25 cable. This board requires a custom cable to connect to its sensors. Use this guide when making a new cable. \n\n\n\n\n\n\nUse a multimeter set to continuity mode to ensure connections. Have a team member verify when finished."
		(exclude_from_sim no)
		(at 12.7 140.716 0)
		(size 159.258 62.124)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width -0.0001)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 2.794 2.794)
				(thickness 0.3493)
			)
			(justify left)
		)
		(uuid "6b5cd15d-aec4-4293-9264-952b1ae12ffd")
	)
	(text_box "NOTE:\nWhile the pinouts are the same for the left and right side of the board, the UART addresses are different.\n\nSensor Callout\nRight: 4,5,6,1,2,3\nLeft: 1,2,3,4,5,6"
		(exclude_from_sim no)
		(at 233.934 121.1288 0)
		(size 50.292 43.4632)
		(margins 0.9525 0.9525 0.9525 0.9525)
