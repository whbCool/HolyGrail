	(title_block
		(title "DB25 Pinout")
	)
	(lib_symbols)
	(text "Make sure to check all connections prior to connecting to power. \n\nIncorrect wiring can cause permanent damage to sensors and/or\nboard. "
		(exclude_from_sim no)
		(at 13.462 173.99 0)
		(effects
			(font
				(size 2.794 2.794)
				(bold yes)
				(color 210 0 7 1)
			)
			(justify left)
		)
		(uuid "40cabc15-567f-465c-9758-47ceef0d568a")
	)
	(text_box "This is the pinout for a custom female DB25 cable. This board requires a custom cable to connect to its sensors. Use this guide when making a new cable. Cable RX goes to Board TX, same for TX to RX. \n\n\n\n\n\n\nUse a multimeter set to continuity mode to ensure connections. Have a team member verify when finished."
		(exclude_from_sim no)
		(at 12.7 140.716 0)
