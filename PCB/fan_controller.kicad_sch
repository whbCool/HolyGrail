	(text "Fan Controller\n\nSet to turn on a fan when temperatures reach ~65° C.\n\nThermistors measure the temperature of the LMR33640 \nand the AP63205. LM393DR follows OR Logic.\n\nIncorporates a ~0.5 second soft-start.\n\nC41 is an ALUMINUM capacitor!"
		(exclude_from_sim no)
		(at 166.116 29.972 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "38eea0ea-4470-4f78-9273-cacd43142226")
	)
	(text "Temperature Calculation (Kelvin)\n\nR67/R68 = R_0 * e^(β * (1/T - 1/T_0))\n\nR_0 = 10 kOhm\nT_0 = 298.15° K\n\nβ: 3435 (Refer to datahseet)"
		(exclude_from_sim no)
		(at 174.244 57.912 0)
		(effects
			(font
				(size 1.143 1.143)
			)
		)
		(uuid "82f69b34-3b7d-4742-b38a-a74929d1826a")
	)
