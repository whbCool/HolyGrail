	(text "Clock Fan-out Buffer\n\nThis IC replicates the 14.7456 MHz reference signal onto independent, buffered paths,\nmitigating clock skew and achieving lossless data synchronization."
		(exclude_from_sim no)
		(at 88.138 159.004 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "06833f12-585d-4a9c-b7a8-60be5217f0d0")
	)
	(text_box "ESP32: Ingests sensor data and publishes status updates to the show network."
		(exclude_from_sim no)
		(at 39.37 71.7184 0)
		(size 32.258 8.0376)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width -0.0001)
			(type dash)
			(color 0 0 0 1)
		)
		(fill
