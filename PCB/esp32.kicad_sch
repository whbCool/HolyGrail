			)
			(justify top)
		)
		(uuid "17d7dac1-b355-4208-9f0a-b938763e711d")
	)
	(text_box "Status LEDs:\n\nSCLK - Lights up when there are active SPI bus transactions between the ESP and the SC16IS752 bridge array.\n\nIRQ - Lights up when a hardware interrupt request is triggered by incoming sensor data."
		(exclude_from_sim no)
		(at 105.41 95.758 0)
		(size 28.956 28.194)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width -0.0001)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify top)
		)
		(uuid "50458c62-7854-4b50-b3d4-b27e0fd5e9db")
	)
	(text_box "ESP32 Programming\nGPIO Pins\n\nInterrupt: 4\nSCLK: 18\nMISO: 19\nMOSI: 23\nReset: 24\nOE: 27\n\nEthernet Chip Select:\n5 (Active Low)\n\nStatus LED: 21\n\nLine Decoder\nA0: 25\nA1: 26\nA2: 32\nEnable: 33\n\nUART Clock Frequency:\n14.7456 MHz\n\nSPI speed: <20MHz\n(16 Mhz recommended)\n\nUse Static IP Addressing\n\nUse MQTT (Need a spare\ncomputer)\n\nThermal management is\nhardware triggered. See\npage 7 for more info."
		(exclude_from_sim no)
		(at 13.462 13.462 0)
		(size 23.114 59.1534)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0.381)
